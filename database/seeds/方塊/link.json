{
  "id": "方塊:方塊:link",
  "名稱": {
    "en": "Link",
    "zh-tw": "連結",
    "zh-cn": "链接",
    "vi": "Liên kết"
  },
  "描述": {
    "en": "A hyperlink component, commonly used in MenuBarItem, Footer, ListItem",
    "zh-tw": "超連結元件，常用於 MenuBarItem、Footer、ListItem",
    "zh-cn": "超链接元件，常用于 MenuBarItem、Footer、ListItem",
    "vi": "Thành phần liên kết, thường dùng trong MenuBarItem, Footer, ListItem"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:基礎", "方塊:標籤:互動"],
  "模式": "內建",
  "元件路徑": "Link",
  "屬性定義": {
    "href": {
      "type": "string",
      "description": "Link URL",
      "required": false,
      "default": "#"
    },
    "target": {
      "type": "string",
      "description": "Link target attribute",
      "required": false,
      "default": "_self",
      "options": ["_self", "_blank", "_parent", "_top"]
    },
    "color": {
      "type": "string",
      "description": "Link color theme",
      "required": false,
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "neutral"]
    },
    "variant": {
      "type": "string",
      "description": "Link style variant",
      "required": false,
      "default": "ghost",
      "options": ["ghost", "solid", "outline"]
    },
    "underline": {
      "type": "boolean",
      "description": "Show underline",
      "required": false,
      "default": true
    },
    "disabled": {
      "type": "boolean",
      "description": "Disabled state",
      "required": false,
      "default": false
    },
    "children": {
      "type": "component",
      "description": "Link content",
      "required": false
    }
  },
  "預設參數": {
    "href": "#",
    "color": "primary",
    "variant": "ghost",
    "underline": true,
    "children": ["連結"]
  }
}