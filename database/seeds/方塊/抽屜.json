{
  "id": "方塊:方塊:抽屜",
  "名稱": { "en": "Drawer", "zh-tw": "抽屜", "vi": "Ngăn kéo" },
  "描述": {
    "en": "Alpine.js powered slide-in drawer. Supports left/right/top/bottom positions, backdrop close, and configurable state. Content passed as children.",
    "zh-tw": "Alpine.js 驅動的滑入式抽屜面板。支援上/下/左/右四方向、背景點擊關閉、自訂 state。內容透過 children 傳入。",
    "vi": "Ngăn kéo trượt được điều khiển bởi Alpine.js. Hỗ trợ bốn hướng, đóng khi nhấp nền, state tùy chỉnh. Nội dung truyền qua children."
  },
  "from": "方塊:方塊:容器",
  "className": "fixed z-50 shadow-lg transition-transform duration-300 pointer-events-auto flex flex-col overflow-hidden !m-0 max-w-full",
  "args": {
    "state": {
      "type": "string",
      "description": "Alpine store 狀態名稱（$store.drawers.{state}）",
      "default": "drawerOpen"
    },
    "color": {
      "type": "string",
      "description": "色彩主題（來自容器）",
      "default": "base",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "position": {
      "type": "string",
      "description": "抽屜滑出方向（自動調整 className / 寬度 / transition）",
      "default": "left",
      "options": ["left", "right", "top", "bottom"],
      "variants": {
        "left": {
          "className": "left-0 inset-y-0 h-screen",
          "style": { "width": "320px" },
          "alpine": {
            "attrs": {
              "x-transition:enter": "drawer-left-enter",
              "x-transition:leave": "drawer-left-leave"
            }
          }
        },
        "right": {
          "className": "right-0 inset-y-0 h-screen",
          "style": { "width": "320px" },
          "alpine": {
            "attrs": {
              "x-transition:enter": "drawer-right-enter",
              "x-transition:leave": "drawer-right-leave"
            }
          }
        },
        "top": {
          "className": "top-0 inset-x-0 max-h-[85vh]",
          "style": { "width": "100%" },
          "alpine": {
            "attrs": {
              "x-transition:enter": "drawer-top-enter",
              "x-transition:leave": "drawer-top-leave"
            }
          }
        },
        "bottom": {
          "className": "bottom-0 inset-x-0 max-h-[85vh]",
          "style": { "width": "100%" },
          "alpine": {
            "attrs": {
              "x-transition:enter": "drawer-bottom-enter",
              "x-transition:leave": "drawer-bottom-leave"
            }
          }
        }
      }
    }
  },
  "alpine": {
    "init": "$store.drawers = $store.drawers || {}",
    "attrs": { "show": "$store.drawers.{state}" }
  },
  "on": {
    "click.stop": ""
  },
  "slots": {
    "backdrop": {
      "from": "div",
      "className": "fixed inset-0 bg-neutral-900/50 pointer-events-auto transition-opacity duration-300",
      "alpine": {
        "attrs": { "show": "$store.drawers.{state}" }
      },
      "on": {
        "click": "$store.drawers.{state} = false"
      }
    },
    "header": {
      "from": "div",
      "className": "shrink-0"
    },
    "content": {
      "from": "div",
      "className": "flex-1 overflow-hidden relative z-10 flex flex-col"
    },
    "footer": {
      "from": "div",
      "className": "shrink-0"
    }
  },
  "可刪除": false
}
