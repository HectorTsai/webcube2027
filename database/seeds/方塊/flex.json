{
  "id": "方塊:方塊:flex",
  "名稱": {
    "en": "Flex",
    "zh-tw": "彈性佈局",
    "zh-cn": "弹性布局",
    "vi": "Bố cục linh hoạt"
  },
  "描述": {
    "en": "A flex layout component for creating flexible container layouts. IMPORTANT FOR AI: This component uses CSS Flexbox to arrange child elements. Usage example: <Flex direction=\"row\" gap=\"md\" justify=\"between\"><div>Item 1</div><div>Item 2</div></Flex>",
    "zh-tw": "用於建立彈性容器佈局的彈性佈局元件。AI注意：此元件使用 CSS Flexbox 來排列子元素。使用範例：<Flex direction=\"row\" gap=\"md\" justify=\"between\"><div>項目1</div><div>項目2</div></Flex>",
    "zh-cn": "用于创建弹性容器布局的弹性布局元件。AI注意：此元件使用 CSS Flexbox 来排列子元素。使用示例：<Flex direction=\"row\" gap=\"md\" justify=\"between\"><div>项目1</div><div>项目2</div></Flex>",
    "vi": "Thành phần bố cục linh hoạt để tạo bố cục container linh hoạt. LƯU Ý CHO AI: Thành phần này sử dụng CSS Flexbox để sắp xếp các phần tử con. Ví dụ sử dụng: <Flex direction=\"row\" gap=\"md\" justify=\"between\"><div>Mục 1</div><div>Mục 2</div></Flex>"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:佈局", "方塊:標籤:容器", "方塊:標籤:基礎"],
  "模式": "內建",
  "元件路徑": "Flex",
