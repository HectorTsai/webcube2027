{
  "id": "方塊:方塊:divider",
  "名稱": {
    "en": "Divider",
    "zh-tw": "分隔線",
    "zh-cn": "分隔线",
    "vi": "Đường phân cách"
  },
  "描述": {
    "en": "A divider component for separating content sections",
    "zh-tw": "用於分隔內容區域的分隔線元件",
    "zh-cn": "用于分隔内容区域的分隔线元件",
    "vi": "Thành phần đường phân cách để tách các phần nội dung"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:基礎", "方塊:標籤:佈局"],
  "模式": "內建",
  "元件路徑": "Divider",
  "屬性定義": {
    "color": {
      "type": "string",
      "description": "Divider color，支援所有顏色（包涵 -90/-70/-50/-30/-10 意指與原色亮度差異，如 primary是亮色，primary-10 是 primary 色的暗色）",
      "required": false,
      "default": "neutral",
      "options": [
        "primary", "primary-90", "primary-70", "primary-50", "primary-30", "primary-10",
        "secondary", "secondary-90", "secondary-70", "secondary-50", "secondary-30", "secondary-10",
        "accent", "accent-90", "accent-70", "accent-50", "accent-30", "accent-10",
        "info", "info-90", "info-70", "info-50", "info-30", "info-10",
        "success", "success-90", "success-70", "success-50", "success-30", "success-10",
        "warning", "warning-90", "warning-70", "warning-50", "warning-30", "warning-10",
        "error", "error-90", "error-70", "error-50", "error-30", "error-10",
        "base", "base-90", "base-70", "base-50", "base-30", "base-10",
        "neutral", "neutral-90", "neutral-70", "neutral-50", "neutral-30", "neutral-10"
      ],
      "example": "primary"
    },
    "horizontal": {
      "type": "boolean",
      "description": "Divider 是否水平方向分隔線",
      "required": false,
      "default": false
    },
    "position": {
      "type": "string",
      "description": "Divider position",
      "required": false,
      "default": "center",
      "options": ["start", "center", "end"]
    }
  },
  "子方塊": [],
  "對外參數": {},
  "程式碼": "",
  "審核狀態": "approved",
  "上架狀態": true,
  "可刪除": false
}