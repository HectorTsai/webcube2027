{
  "id": "方塊:方塊:頁尾",
  "名稱": { "en": "Footer", "zh-tw": "頁尾", "vi": "Chân trang" },
  "描述": {
    "en": "Page footer section built on Container. Centered column layout with configurable color, variant, padding, and gap. Content is passed as children.",
    "zh-tw": "基於 Container 的頁面頁尾區塊。置中欄佈局，可設定 color、variant、padding 與 gap。內容透過 children 傳入。",
    "vi": "Phần chân trang dựa trên Container. Bố cục cột căn giữa với màu sắc, biến thể, đệm và khoảng cách có thể cấu hình. Nội dung được truyền qua children."
  },
  "from": "方塊:方塊:容器",
  "defaults": { 
    "border": "none",
    "shadow": "none",
    "rounded": "none"
  },
  "mergedArgs": {
    "currentYear": "@api/v1/temporal/fullYear",
    "prefix": "@api/v1/translate/copyright",
    "suffix": "@api/v1/translate/all rights reserved"
  },
  "args": {
    "color": {
      "type": "string",
      "description": "色彩主題",
      "default": "base",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "variant": {
      "type": "string",
      "description": "樣式變體",
      "default": "solid"
    },
    "direction": {
      "type": "string",
      "description": "排列方向",
      "default": "col",
      "options": ["col", "row"]
    },
    "padding": {
      "type": "string",
      "description": "內距",
      "default": "xs",
      "options": ["none", "xs", "sm", "md", "lg", "xl", "2xl"]
    },
    "width": {
      "type": "string",
      "description": "寬度",
      "default": "full"
    },
    "gap": {
      "type": "string",
      "description": "間距",
      "default": "xs",
      "options": ["none", "xs", "sm", "md", "lg", "xl"]
    },
    "className": {
      "type": "string",
      "description": "額外的 CSS 類別（如 items-center justify-center text-sm）",
      "default": "items-center justify-center text-sm"
    },
    "copyright": {
      "type": "object",
      "description": "版權資訊物件，包含 公司、網址、開始年份 等欄位",
      "default": {}
    }
  },
  "children": [
    {
      "from": "div",
      "className": "flex flex-row items-center justify-center gap-1 text-center text-sm",
      "children": [
        {
          "from": "span",
          "text": "{prefix} \u00a9 {copyright.開始年份}-{currentYear}"
        },
        {
          "from": "方塊:方塊:超連結",
          "href": "{copyright.網址}",
          "target": "_blank",
          "className": "!border-none !shadow-none",
          "children": [
            {
              "from": "span",
              "text": "{copyright.公司}"
            }
          ]
        },
        {
          "from": "span",
          "text": "{suffix}."
        }
      ]
    }
  ],
  "可刪除": false
}
