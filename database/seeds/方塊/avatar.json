{
  "id": "方塊:方塊:avatar",
  "名稱": {
    "en": "Avatar",
    "zh-tw": "頭像",
    "zh-cn": "头像",
    "vi": "Ảnh đại diện"
  },
  "描述": {
    "en": "A user avatar component with image and fallback options",
    "zh-tw": "具有圖像和備用選項的用戶頭像元件",
    "zh-cn": "具有图像和备用选项的用户头像元件",
    "vi": "Thành phần ảnh đại diện người dùng với tùy chọn hình ảnh và dự phòng"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:媒體", "方塊:標籤:個人化"],
  "模式": "內建",
  "元件路徑": "Avatar",
  "屬性定義": {
    "icon": {
      "type": "string",
      "description": "圖示的資料庫id，可以從資料庫取得圖示資料",
      "required": false,
      "default": ""
    },
    "image": {
      "type": "string",
      "description": "圖片的資料庫id,可以從哩奧庫取得圖片資料",
      "required": false,
      "default": ""
    },
    "svg":{
      "type": "string",
      "description": "SVG content，直接填入svg內容",
      "required": false,
      "default": ""
    },
    "src": {
      "type": "string",
      "description": "Image source URL",
      "required": false,
      "default": ""
    },
    "size": {
      "type": "string",
      "description": "Avatar size",
      "required": false,
      "default": "md",
      "options": ["xs", "sm", "md", "lg", "xl", "2xl", "3xl"]
    },
    "color": {
      "type": "string",
      "description": "Avatar color",
      "required": false,
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "variant": {
      "type": "string",
      "description": "Avatar style variant",
      "required": false,
      "default": "crystal",
      "options": ["solid", "outline", "ghost", "dot", "dashed", "double", "gradient-right", "gradient-left", "gradient-up", "gradient-down", "gradient-middle", "gradient-diagonal", "gradient-center", "gradient-cone", "crystal", "diagonal-stripes", "glow", "minimalist"]
    },
    "className": {
      "type": "string",
      "description": "額外的類名，用於自訂頭像樣式",
      "required": false,
      "default": ""
    }
  },
  "子方塊": [],
  "對外參數": {},
  "程式碼": "",
  "審核狀態": "approved",
  "上架狀態": true,
  "可刪除": false
}