{
  "id": "方塊:方塊:popup",
  "名稱": {
    "en": "Popup",
    "zh-tw": "彈出框",
    "zh-cn": "弹出框",
    "vi": "Hộp bật lên"
  },
  "描述": {
    "en": "A popup component for displaying contextual content. IMPORTANT FOR AI: This component can be used to display tooltips, dropdowns, or other contextual information. Usage example: <Popup state=\"showPopup\">Popup content</Popup>",
    "zh-tw": "用於顯示上下文內容的彈出框元件。AI注意：此元件可用於顯示工具提示、下拉選單或其他上下文資訊。使用範例：<Popup state=\"showPopup\">彈出框內容</Popup>",
    "zh-cn": "用于显示上下文内容的弹出框元件。AI注意：此元件可用于显示工具提示、下拉菜单或其他上下文信息。使用示例：<Popup state=\"showPopup\">弹出框内容</Popup>",
    "vi": "Thành phần hộp bật lên để hiển thị nội dung ngữ cảnh. LƯU Ý CHO AI: Thành phần này có thể được sử dụng để hiển thị chú giải công cụ, menu thả xuống hoặc thông tin ngữ cảnh khác. Ví dụ sử dụng: <Popup state=\"showPopup\">nội dung hộp bật lên</Popup>"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:互動", "方塊:標籤:容器", "方塊:標籤:進階"],
  "模式": "內建",
  "元件路徑": "Popup",
  "屬性定義": {
    "state": {
      "type": "string",
      "description": "Alpine.js Store 中的狀態鍵名，必填，不可重複",
      "required": true,
      "default": ""
    },
    "autoClose": {
      "type": "boolean",
      "description": "是否自動關閉",
      "required": false,
      "default": false
    },
    "position": {
      "type": "string",
      "description": "定位方式",
      "required": false,
      "default": "absolute",
      "options": ["absolute", "fixed"]
    },
    "offset": {
      "type": "object",
      "description": "定位偏移",
      "required": false,
      "default": {},
      "properties": {
        "top": {
          "type": "string",
          "description": "上偏移",
          "required": false
        },
        "left": {
          "type": "string",
          "description": "左偏移",
          "required": false
        },
        "right": {
          "type": "string",
          "description": "右偏移",
          "required": false
        },
        "bottom": {
          "type": "string",
          "description": "下偏移",
          "required": false
        }
      }
    },
    "variant": {
      "type": "string",
      "description": "彈出框樣式變體, 預設會依據骨架設定變化，非必要不需設定。",
      "required": false,
      "default": "solid",
      "options": ["solid", "outline", "ghost", "dot", "dashed", "double", "gradient-right", "gradient-left", "gradient-up", "gradient-down", "gradient-middle", "gradient-diagonal", "gradient-center", "gradient-cone", "crystal", "diagonal-stripes", "glow", "minimalist"]
    },
    "color": {
      "type": "string",
      "description": "彈出框顏色",
      "required": false,
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "className": {
      "type": "string",
      "description": "彈出框額外 CSS 類別",
      "required": false,
      "default": ""
    }
  },
  "子方塊": [],
  "對外參數": {},
  "程式碼": "",
  "審核狀態": "approved",
  "上架狀態": true,
  "可刪除": false
}