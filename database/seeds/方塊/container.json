{
  "id": "方塊:方塊:Container",
  "名稱": {"en": "Container", "zh-tw": "容器", "vi": "Container"},
  "描述": {
    "en": "Universal container cube, supports active/hover states and color themes",
    "zh-tw": "通用容器方塊，支援 active/hover 狀態與色彩主題", 
    "vi": "Khối chứa phổ quát, hỗ trợ trạng thái active/hover và chủ đề màu sắc"
  },
  "from": "方塊:方塊:Container",
  "args": {
    "color": {
      "type": "string",
      "description": "色彩主題",
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "width": {
      "type": "string",
      "description": "CSS width",
      "default": "auto"
    },
    "height": {
      "type": "string",
      "description": "CSS height",
      "default": "auto"
    },
    "padding": {
      "type": "string",
      "description": "Padding 尺寸",
      "default": "md",
      "options": ["none", "xs", "sm", "md", "lg", "xl"]
    },
    "active": {
      "type": "boolean",
      "description": "供電狀態",
      "default": true
    },
    "hover": {
      "type": "boolean",
      "description": "允許懸停效果",
      "default": false
    },
    "activeStateName": {
      "type": "string",
      "description": "Alpine store 屬性名稱（用於動態切換）",
      "default": ""
    }
  }
}