{
  "id": "方塊:方塊:card",
  "名稱": {
    "en": "Card",
    "zh-tw": "卡片",
    "zh-cn": "卡片",
    "vi": "Thẻ"
  },
  "描述": {
    "en": "A card component with image support and sub-components (Title, Body, Foot). IMPORTANT FOR AI: Supports image display based on direction (column: top, row: left). Usage example: <Card image='image-id'><CardTitle>Title</CardTitle><CardBody>Content</CardBody><CardFoot>Footer</CardFoot></Card>",
    "zh-tw": "支援圖像和子元件（標題、內容、頁腳）的卡片元件。AI注意：根據方向顯示圖像（垂直：上方，水平：左側）。使用範例：<Card image='圖像ID'><CardTitle>標題</CardTitle><CardBody>內容</CardBody><CardFoot>頁腳</CardFoot></Card>",
    "zh-cn": "支持图像和子元件（标题、内容、页脚）的卡片元件。AI注意：根据方向显示图像（垂直：上方，水平：左侧）。使用示例：<Card image='图像ID'><CardTitle>标题</CardTitle><CardBody>内容</CardBody><CardFoot>页脚</CardFoot></Card>",
    "vi": "Thành phần thẻ hỗ trợ hình ảnh và các thành phần con (Tiêu đề, Nội dung, Chân trang). LƯU Ý CHO AI: Hỗ trợ hiển thị hình ảnh dựa trên hướng (cột: trên cùng, hàng: bên trái). Ví dụ sử dụng: <Card image='id-hình-ảnh'><CardTitle>Tiêu đề</CardTitle><CardBody>Nội dung</CardBody><CardFoot>Chân trang</CardFoot></Card>"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:基礎", "方塊:標籤:內容", "方塊:標籤:容器"],
  "模式": "內建",
  "元件路徑": "Card",
  "屬性定義": {
    "image": {
      "type": "string",
      "description": "圖像資料庫ID",
      "required": false,
      "default": ""
    },
    "src": {
      "type": "string",
      "description": "圖像URL",
      "required": false,
      "default": ""
    },
    "svg": {
      "type": "string",
      "description": "SVG內容",
      "required": false,
      "default": ""
    },
    "variant": {
      "type": "string",
      "description": "Card variant style, 預設會依據骨架設定變化，非必要不需設定。",
      "required": false,
      "default": "solid",
      "options": ["solid", "outline", "ghost", "dot", "dashed", "double", "gradient-right", "gradient-left", "gradient-up", "gradient-down", "gradient-middle", "gradient-diagonal", "gradient-center", "gradient-cone", "crystal", "diagonal-stripes", "glow", "minimalist"]
    },
    "color": {
      "type": "string",
      "description": "Card color theme",
      "required": false,
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "direction": {
      "type": "string",
      "description": "Content direction",
      "required": false,
      "default": "column",
      "options": ["row", "column"]
    },
    "padding": {
      "type": "string",
      "description": "Padding size",
      "required": false,
      "default": "md",
      "options": ["none", "xs", "sm", "md", "lg", "xl", "2xl"]
    },
    "margin": {
      "type": "string",
      "description": "Margin size",
      "required": false,
      "default": "none",
      "options": ["none", "xs", "sm", "md", "lg", "xl", "auto"]
    },
    "align": {
      "type": "string",
      "description": "Alignment",
      "required": false,
      "default": "start",
      "options": ["start", "center", "end", "stretch"]
    },
    "justify": {
      "type": "string",
      "description": "Justification",
      "required": false,
      "default": "start",
      "options": ["start", "center", "end", "between", "around", "evenly"]
    },
    "gap": {
      "type": "string",
      "description": "Gap size",
      "required": false,
      "default": "none",
      "options": ["none", "xs", "sm", "md", "lg", "xl"]
    }
  },
