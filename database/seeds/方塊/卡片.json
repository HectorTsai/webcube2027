{
  "id": "方塊:方塊:卡片",
  "名稱": {
    "en": "Card",
    "zh-tw": "卡片",
    "vi": "Thẻ"
  },
  "描述": {
    "en": "Card cube built on Container, following daisyUI structure: media slot (image, no padding) + body slot (content, padded). Direction variant switches column/row layout.",
    "zh-tw": "卡片方塊，基於容器建構，仿 daisyUI 結構：media slot（圖片，無 padding）+ body slot（內容，自動接收 JSX children）。Direction variant 切換 column/row 佈局。",
    "vi": "Khối thẻ, xây dựng trên Container."
  },
  "from": "方塊:方塊:容器",
  "className": "rounded-md shadow-md overflow-hidden",
  "args": {
    "color": {
      "type": "string",
      "description": "色彩主題",
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "direction": {
      "type": "string",
      "description": "佈局方向 — column：圖片佔滿上方，row：圖片佔滿左側",
      "default": "column",
      "options": ["column", "row"],
      "variants": {
        "column": {
          "className": "flex flex-col"
        },
        "row": {
          "className": "flex flex-row"
        }
      }
    },
    "active": {
      "type": "boolean",
      "description": "供電狀態",
      "default": true
    },
    "hover": {
      "type": "boolean",
      "description": "允許懸停效果",
      "default": false
    }
  },
  "slots": {
    "media": {
      "from": "div"
    },
    "body": {
      "from": "div",
      "className": "p-4 flex-1 min-w-0"
    }
  }
}
