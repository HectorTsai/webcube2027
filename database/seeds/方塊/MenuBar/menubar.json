{
  "id": "方塊:方塊:menubar",
  "名稱": {
    "en": "Menu Bar",
    "zh-tw": "選單列",
    "zh-cn": "菜单栏",
    "vi": "Thanh menu"
  },
  "描述": {
    "en": "A menu bar component for navigation menus. IMPORTANT FOR AI: This component accepts MenuItem sub-components as children. Usage example: <MenuBar logo={<Logo />}><MenuItem>Home</MenuItem><MenuItem>About</MenuItem></MenuBar>",
    "zh-tw": "用於導航選單的選單列元件。AI注意：此元件接受MenuItem子元件作為子元素。使用範例：<MenuBar logo={<Logo />}><MenuItem>首頁</MenuItem><MenuItem>關於</MenuItem></MenuBar>",
    "zh-cn": "用于导航菜单的菜单栏元件。AI注意：此元件接受MenuItem子元件作为子元素。使用示例：<MenuBar logo={<Logo />}><MenuItem>首页</MenuItem><MenuItem>关于</MenuItem></MenuBar>",
    "vi": "Thành phần thanh menu cho menu điều hướng. LƯU Ý CHO AI: Thành phần này chấp nhận các thành phần con MenuItem làm con. Ví dụ sử dụng: <MenuBar logo={<Logo />}><MenuItem>Trang chủ</MenuItem><MenuItem>Giới thiệu</MenuItem></MenuBar>"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:導航", "方塊:標籤:互動", "方塊:標籤:組合", "方塊:標籤:進階"],
  "模式": "內建",
  "元件路徑": "MenuBar",
  "屬性定義": {
    "logo": {
      "type": "any",
      "description": "Logo 元素",
      "required": false,
      "default": ""
    },
    "menuItems": {
      "type": "any",
      "description": "選單項目",
      "required": false,
      "default": ""
    },
    "footer": {
      "type": "any",
      "description": "右側 Footer 元素",
      "required": false,
      "default": ""
    },
    "variant": {
      "type": "string",
      "description": "選單列樣式變體, 預設會依據骨架設定變化，非必要不需設定。",
      "required": false,
      "default": "solid",
      "options": ["solid", "outline", "ghost", "dot", "dashed", "double", "gradient-right", "gradient-left", "gradient-up", "gradient-down", "gradient-middle", "gradient-diagonal", "gradient-center", "gradient-cone", "crystal", "diagonal-stripes", "glow", "minimalist"]
    },
    "color": {
      "type": "string",
      "description": "選單列顏色",
      "required": false,
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "width": {
      "type": "string",
      "description": "選單列寬度",
      "required": false,
      "default": "full",
      "options": ["xs", "sm", "md", "lg", "xl", "full", "auto"]
    },
    "padding": {
      "type": "string",
      "description": "選單列內距",
      "required": false,
      "default": "md",
      "options": ["none", "xs", "sm", "md", "lg", "xl", "2xl"]
    },
    "sticky": {
      "type": "boolean",
      "description": "是否固定在頂部",
      "required": false,
      "default": false
    },
    "responsive": {
      "type": "boolean",
      "description": "是否在移動設備上使用 Drawer",
      "required": false,
      "default": false
    },
    "drawerState": {
      "type": "string",
      "description": "Drawer 的狀態鍵名",
      "required": true,
      "default": ""
    },
    "className": {
      "type": "string",
      "description": "選單列額外 CSS 類別",
      "required": false,
      "default": ""
    }
  },
  "子方塊": [],
  "對外參數": {},
  "程式碼": "",
  "審核狀態": "approved",
  "上架狀態": true,
  "可刪除": false
}