{
  "id": "方塊:方塊:menubar",
  "名稱": {
    "en": "Menu Bar",
    "zh-tw": "選單列",
    "zh-cn": "菜单栏",
    "vi": "Thanh menu"
  },
  "描述": {
    "en": "A menu bar component for navigation menus. IMPORTANT FOR AI: This component accepts MenuHead, MenuItem, MenuFoot sub-components as children. Usage example: <MenuBar responsive><MenuHead>Logo</MenuHead><MenuItem>Home</MenuItem><MenuFoot><Button>Login</Button></MenuFoot></MenuBar>",
    "zh-tw": "用於導航選單的選單列元件。AI注意：此元件接受 MenuHead、MenuItem、MenuFoot 子元件作為 children。使用範例：<MenuBar responsive><MenuHead>Logo</MenuHead><MenuItem>首頁</MenuItem><MenuFoot><Button>登入</Button></MenuFoot></MenuBar>",
    "zh-cn": "用于导航菜单的菜单栏元件。AI注意：此元件接受 MenuHead、MenuItem、MenuFoot 子元件作为 children。使用示例：<MenuBar responsive><MenuHead>Logo</MenuHead><MenuItem>首页</MenuItem><MenuFoot><Button>登录</Button></MenuFoot></MenuBar>",
    "vi": "Thành phần thanh menu cho menu điều hướng. LƯU Ý CHO AI: Thành phần này chấp nhận các thành phần con MenuHead, MenuItem, MenuFoot làm children. Ví dụ sử dụng: <MenuBar responsive><MenuHead>Logo</MenuHead><MenuItem>Trang chủ</MenuItem><MenuFoot><Button>Đăng nhập</Button></MenuFoot></MenuBar>"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:導航", "方塊:標籤:互動", "方塊:標籤:組合", "方塊:標籤:進階"],
  "模式": "內建",
  "元件路徑": "MenuBar",
  "屬性定義": {
    "variant": {
      "type": "string",
      "description": "選單列樣式變體, 預設會依據骨架設定變化，非必要不需設定。",
      "required": false,
      "default": "solid",
      "options": ["solid", "outline", "ghost", "dot", "dashed", "double", "gradient-right", "gradient-left", "gradient-up", "gradient-down", "gradient-middle", "gradient-diagonal", "gradient-center", "gradient-cone", "crystal", "diagonal-stripes", "glow", "minimalist"]
    },
    "color": {
      "type": "string",
      "description": "選單列顏色",
      "required": false,
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "width": {
      "type": "string",
      "description": "選單列寬度",
      "required": false,
      "default": "full",
      "options": ["xs", "sm", "md", "lg", "xl", "full", "auto"]
    },
    "padding": {
      "type": "string",
      "description": "選單列內距",
      "required": false,
      "default": "md",
      "options": ["none", "xs", "sm", "md", "lg", "xl", "2xl"]
    },
    "sticky": {
      "type": "boolean",
      "description": "是否固定在頂部",
      "required": false,
      "default": false
    },
    "responsive": {
      "type": "boolean",
      "description": "是否在移動設備上使用 Drawer",
      "required": false,
      "default": false
    },
    "drawerState": {
      "type": "string",
      "description": "Drawer 的狀態鍵名",
      "required": false,
      "default": "menuDrawer"
    },
    "className": {
      "type": "string",
      "description": "選單列額外 CSS 類別",
      "required": false,
      "default": ""
    }
  },
  "子方塊": ["方塊:方塊:menubar-head", "方塊:方塊:menubar-item", "方塊:方塊:menubar-foot"],
  "預設參數": {
    "color": "primary",
    "variant": "solid",
    "padding": "md",
    "responsive": true,
    "drawerState": "menuDrawer",
    "children": [
