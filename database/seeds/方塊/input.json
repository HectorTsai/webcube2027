{
  "id": "方塊:方塊:input",
  "名稱": {
    "en": "Input",
    "zh-tw": "輸入框",
    "zh-cn": "输入框",
    "vi": "Ô nhập liệu"
  },
  "描述": {
    "en": "A form input component for user data entry",
    "zh-tw": "用於用戶數據輸入的表單輸入框元件",
    "zh-cn": "用于用户数据输入的表单输入框元件",
    "vi": "Thành phần nhập liệu biểu mẫu để nhập dữ liệu người dùng"
  },
  "售價": 0,
  "標籤集": ["方塊:標籤:表單", "方塊:標籤:互動"],
  "模式": "內建",
  "元件路徑": "Input",
  "屬性定義": {
    "frontLabel": {
      "type": "string",
      "description": "前端標籤",
      "required": false,
      "default": ""
    },
    "endLabel": {
      "type": "string",
      "description": "後端標籤",
      "required": false,
      "default": ""
    },
    "floatLabel": {
      "type": "string",
      "description": "浮動標籤",
      "required": false,
      "default": ""
    },
    "type": {
      "type": "string",
      "description": "輸入類型",
      "required": false,
      "default": "text",
      "options": ["text", "password", "email", "number", "tel", "url", "search"]
    },
    "placeholder": {
      "type": "string",
      "description": "佔位文字",
      "required": false,
      "default": ""
    },
    "value": {
      "type": "string",
      "description": "輸入值",
      "required": false,
      "default": ""
    },
    "variant": {
      "type": "string",
      "description": "輸入框樣式變體, 預設會依據骨架設定變化，非必要不需設定。",
      "required": false,
      "default": "solid",
      "options": ["solid", "outline", "ghost", "dot", "dashed", "double", "gradient-right", "gradient-left", "gradient-up", "gradient-down", "gradient-middle", "gradient-diagonal", "gradient-center", "gradient-cone", "crystal", "diagonal-stripes", "glow", "minimalist"]
    },
    "color": {
      "type": "string",
      "description": "輸入框顏色",
      "required": false,
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "className": {
      "type": "string",
      "description": "輸入框額外 CSS 類別",
      "required": false,
      "default": ""
    }
  },
  "子方塊": [],
  "對外參數": {},
  "程式碼": "",
  "審核狀態": "approved",
  "上架狀態": true,
  "可刪除": false
}