[
  {
    "id": "方塊:方塊:圖示",
    "名稱": {
      "en": "Icon",
      "zh-tw": "圖示",
      "vi": "Biểu tượng"
    },
    "描述": {
      "en": "A small icon component for displaying icons, symbols, and small graphics. Perfect for buttons, navigation, and UI indicators.",
      "zh-tw": "小型圖示組件，用於顯示圖示、符號和小圖形。適合按鈕、導航和 UI 指示器。",
      "vi": "Một thành phần biểu tượng nhỏ để hiển thị biểu tượng, ký hiệu và đồ họa nhỏ. Hoàn hảo cho các nút, điều hướng và chỉ báo UI."
    },
    "售價": 0,
    "標籤集": [
      "ui",
      "icon",
      "graphic"
    ],
    "模式": "內建",
    "元件路徑": "ui/Icon",
    "屬性定義": {
      "id": {
        "type": "string",
        "description": "Database icon ID for loading stored icons",
        "required": false,
        "example": "圖示:圖示:heart"
      },
      "src": {
        "type": "string",
        "description": "Direct icon file path or URL",
        "required": false,
        "example": "/icons/save.png"
      },
      "svg": {
        "type": "string",
        "description": "SVG string content for AI-generated icons",
        "required": false,
        "example": "<path d='M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z'/>"
      },
      "size": {
        "type": "string",
        "description": "Icon size in pixels",
        "required": false,
        "default": "md",
        "options": [
          "xs",
          "sm",
          "md",
          "lg"
        ],
        "example": "md"
      },
      "color": {
        "type": "string",
        "description": "Icon color (SVG only)",
        "required": false,
        "default": "currentColor",
        "example": "red"
      },
      "className": {
        "type": "string",
        "description": "Additional CSS classes",
        "required": false,
        "example": "custom-icon"
      }
    },
    "子方塊": [],
    "對外參數": {},
    "程式碼": "",
    "審核狀態": "approved",
    "上架狀態": true,
    "可刪除": false
  }
