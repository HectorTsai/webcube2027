{
  "id": "方塊:方塊:超連結",
  "名稱": { "en": "Link", "zh-tw": "超連結", "vi": "Liên kết" },
  "標籤集": ["方塊:標籤:互動元素"],
  "描述": {
    "en": "Link cube built on Container. Inline-flex centered, underlined by default on hover (style-driven). Supports color themes, sizes, and disabled state.",
    "zh-tw": "超連結方塊，基於容器建構。inline-flex 置中，hover 底線由風格控制。支援色彩主題、尺寸與禁用狀態。",
    "vi": "Khối liên kết, xây dựng trên Container."
  },
  "from": "方塊:方塊:容器",
  "tag": "a",
  "className": "c-style-apply",
  "defaults": {
    "display": "inline-flex",
    "align": "center",
    "justify": "center",
    "padding": "none",
    "underline": "none",
    "userSelect": "none",
    "cursor": "pointer"
  },
  "args": {
    "color": {
      "type": "string",
      "description": "色彩主題",
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "size": {
      "type": "string",
      "description": "連結尺寸（控制字級、圓角與內距）",
      "default": "md",
      "options": ["xs", "sm", "md", "lg", "xl"],
      "variants": {
        "xs": { "fontSize": "xs", "rounded": "sm", "padding": "xs" },
        "sm": { "fontSize": "sm", "rounded": "sm", "padding": "sm" },
        "md": { "fontSize": "base", "rounded": "md", "padding": "md" },
        "lg": { "fontSize": "lg", "rounded": "lg", "padding": "lg" },
        "xl": { "fontSize": "xl", "rounded": "lg", "padding": "xl" }
      }
    },
    "disabled": {
      "type": "boolean",
      "description": "是否禁用",
      "default": false
    },
    "active": {
      "type": "boolean",
      "description": "供電狀態（false = neutral 灰階）",
      "default": true
    },
    "hover": {
      "type": "boolean",
      "description": "允許懸停效果",
      "default": true
    }
  },
  "可刪除": false
}
