{
  "id": "方塊:方塊:超連結",
  "名稱": { "en": "Link", "zh-tw": "超連結", "vi": "Liên kết" },
  "描述": {
    "en": "Link cube built on Container. Supports color themes, sizes, disabled state, and href prop.",
    "zh-tw": "超連結方塊，基於容器建構。無底線、支援色彩主題、尺寸、禁用狀態。",
    "vi": "Khối liên kết, xây dựng trên Container."
  },
  "from": "方塊:方塊:容器",
  "tag": "a",
  "className": "cursor-pointer inline-flex items-center justify-center p-0 bg-transparent select-none focus:outline-none focus-visible:ring-2 focus-visible:ring-current/30 no-underline",
  "args": {
    "color": {
      "type": "string",
      "description": "色彩主題",
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "size": {
      "type": "string",
      "description": "連結尺寸（控制內距與字級）",
      "default": "md",
      "options": ["xs", "sm", "md", "lg", "xl"],
      "variants": {
        "xs": { "className": "text-xs rounded", "containerClassName": "px-2 py-1" },
        "sm": { "className": "text-sm rounded", "containerClassName": "px-3 py-1.5" },
        "md": { "className": "text-base rounded-md", "containerClassName": "px-4 py-2" },
        "lg": { "className": "text-lg rounded-lg", "containerClassName": "px-6 py-3" },
        "xl": { "className": "text-xl rounded-lg", "containerClassName": "px-8 py-4" }
      }
    },
    "disabled": {
      "type": "boolean",
      "description": "是否禁用",
      "default": false
    },
    "active": {
      "type": "boolean",
      "description": "供電狀態（false = neutral 灰階）",
      "default": true
    },
    "hover": {
      "type": "boolean",
      "description": "允許懸停效果",
      "default": true
    }
  },
  "可刪除": false
}
