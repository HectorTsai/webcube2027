{
  "id": "方塊:方塊:主選單",
  "名稱": { "en": "Menu Bar", "zh-tw": "主選單", "vi": "Thanh menu" },
  "描述": {
    "en": "Responsive navigation menu bar built on Container. Desktop: horizontal row layout. Mobile: collapses to a hamburger button with Alpine.js drawer toggle. Supports color theming through Container.",
    "zh-tw": "基於 Container 的響應式導航選單列。桌面版：水平 row 佈局。行動版：收合為漢堡選單按鈕，透過 Alpine.js 切換抽屜。支援 Container 的 color 主題。",
    "vi": "Thanh menu điều hướng đáp ứng dựa trên Container. Phiên bản desktop: bố cục row ngang. Phiên bản di động: thu gọn thành nút hamburger, chuyển đổi ngăn kéo qua Alpine.js. Hỗ trợ chủ đề màu sắc của Container."
  },
  "from": "方塊:方塊:容器",
  "containerClassName": "!flex-row items-center !border-none !shadow-none !rounded-none",
  "args": {
    "color": {
      "type": "string",
      "description": "色彩主題",
      "default": "primary",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "padding": {
      "type": "string",
      "description": "內距",
      "default": "sm",
      "options": ["none", "xs", "sm", "md", "lg", "xl", "2xl"]
    },
    "width": {
      "type": "string",
      "description": "寬度",
      "default": "full"
    },
    "gap": {
      "type": "string",
      "description": "間距",
      "default": "md",
      "options": ["none", "xs", "sm", "md", "lg", "xl"]
    },
    "drawerState": {
      "type": "string",
      "description": "行動版抽屜的 Alpine store 狀態名稱",
      "default": "menuDrawer"
    },
    "className": {
      "type": "string",
      "description": "額外的 CSS 類別（如 sticky top-0 z-50）",
      "default": ""
    },
    "items": {
      "type": "array",
      "description": "菜單項目數組，每個項目為頁面 ID（如 頁面:頁面:home）",
      "default": []
    }
  },
  "alpine": {
    "init": "$store.drawers = $store.drawers || {}"
  },
  "mergedArgs": {
    "logo": "@api/v1/info/商標",
    "name": "@api/v1/info/名稱"
  },
  "slots": {
    "brand": {
      "from": "div",
      "className": "flex items-center pr-1 shrink-0 gap-2",
      "children": [
        { "from": "方塊:方塊:圖示", "id": "{logo}", "alt": "{name}", "width": "32", "height": "32" },
        { "from": "span", "className": "font-bold text-lg", "text": "{name}" }
      ]
    },
    "content": {
      "from": "div",
      "className": "hidden md:flex items-center flex-1 gap-4",
      "children": [
        {
          "from": "方塊:方塊:超連結",
          "repeat": "{items}",
          "href": "/page/{item}",
          "className": "!border-none",
          "children": [{ "from": "span", "text": { "$api": { "path": "/api/v1/page/{item}", "field": "標題" } } }]
        }
      ]
    },
    "drawer": {
      "from": "方塊:方塊:抽屜",
      "color": "{color}",
      "state": "{drawerState}",
      "position": "right",
      "mergedArgs": {
        "title": "@api/v1/translate/main menu"
      },
      "slots": {
        "header": { "from": "div", "className": "text-center font-bold text-lg", "text": "{title}" }
      },
      "children": [
        {
          "from": "方塊:方塊:超連結",
          "repeat": "{items}",
          "href": "/page/{item}",
          "className": "block text-left !border-none !shadow-none",
          "on": {
            "click": "$store.drawers.{drawerState} = false"
          },
          "children": [{ "from": "span", "text": { "$api": { "path": "/api/v1/page/{item}", "field": "標題" } } }]
        }
      ]
    },
    "footer": {
      "from": "div",
      "className": "hidden md:flex items-center shrink-0 gap-2"
    }
  },
  "children": [
    {
      "from": "方塊:方塊:按鈕",
      "size": "xs",
      "className": "md:hidden ml-auto !rounded-md",
      "on": {
        "click": "$store.drawers.{drawerState} = !$store.drawers.{drawerState}"
      },
      "children": [
        { "from": "方塊:方塊:圖示", "id": "選單", "size": "md" }
      ]
    }
  ],
  "可刪除": false
}