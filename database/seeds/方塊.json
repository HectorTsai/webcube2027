  {
    "id": "方塊:方塊:主選單",
    "名稱": {
      "en": "Main Menu",
      "zh-tw": "主選單",
      "vi": "Menu Chính"
    },
    "描述": {
      "en": "A main navigation menu component for website header navigation. Supports logo, menu items, and call-to-action buttons.",
      "zh-tw": "網站標頭導航的主選單元件。支援商標、選單項目和行動按鈕。",
      "vi": "Một thành phần menu điều hướng chính cho tiêu đề trang web. Hỗ trợ logo, mục menu và nút kêu gọi hành động."
    },
    "售價": 0,
    "標籤集": ["ui", "navigation", "menu", "header"],
    "模式": "內建",
    "元件路徑": "navigation/MainMenu",
    "屬性定義": {
      "logo": {
        "type": "string",
        "description": "Logo image URL or text",
        "required": false,
        "default": "",
        "example": "/images/logo.png"
      },
      "logoText": {
        "type": "string",
        "description": "Logo text alternative to image",
        "required": false,
        "default": "Brand",
        "example": "MyBrand"
      },
      "menuItems": {
        "type": "array",
        "description": "Array of menu items with label and href",
        "required": true,
        "example": "[{\"label\": \"Home\", \"href\": \"/\"}, {\"label\": \"About\", \"href\": \"/about\"}]"
      },
      "ctaButton": {
        "type": "object",
        "description": "Call-to-action button configuration",
        "required": false,
        "example": "{\"text\": \"Get Started\", \"href\": \"/signup\", \"variant\": \"primary\"}"
      },
      "variant": {
        "type": "string",
        "description": "Menu style variant",
        "required": false,
        "default": "default",
        "options": ["default", "minimal", "centered", "split"],
        "example": "default"
      },
      "sticky": {
        "type": "boolean",
        "description": "Whether menu should stick to top when scrolling",
        "required": false,
        "default": false,
        "example": true
      }
    },
