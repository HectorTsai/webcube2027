  {
    "id": "方塊:方塊:容器",
    "名稱": {
      "en": "Container",
      "zh-tw": "容器",
      "vi": "Container"
    },
    "描述": {
      "en": "A flexible container component for layout and grouping. Provides spacing, alignment, and responsive design capabilities.",
      "zh-tw": "靈活的容器元件，用於佈局和分組。提供間距、對齊和響應式設計功能。",
      "vi": "Một thành phần container linh hoạt cho bố cục và nhóm. Cung cấp khoảng cách, căn chỉnh và khả năng thiết kế phản ứng."
    },
    "售價": 0,
    "標籤集": ["ui", "container", "layout", "flexbox"],
    "模式": "內建",
    "元件路徑": "container/Container",
    "屬性定義": {
      "children": {
        "type": "object",
        "description": "Child elements to render inside the container",
        "required": true,
        "example": "<div>Content here</div>"
      },
      "direction": {
        "type": "string",
        "description": "Flex direction - controls layout orientation",
        "required": false,
        "default": "column",
        "options": ["row", "column", "row-reverse", "column-reverse"],
        "example": "column"
      },
      "align": {
        "type": "string",
        "description": "Cross-axis alignment - controls vertical positioning",
        "required": false,
        "default": "stretch",
        "options": ["start", "center", "end", "stretch"],
        "example": "center"
      },
      "justify": {
        "type": "string",
        "description": "Main-axis alignment - controls horizontal positioning",
        "required": false,
        "default": "start",
        "options": ["start", "center", "end", "between", "around", "evenly"],
        "example": "start"
      },
      "gap": {
        "type": "string",
        "description": "Spacing between child elements",
        "required": false,
        "default": "md",
        "options": ["none", "xs", "sm", "md", "lg", "xl"],
        "example": "md"
      },
      "padding": {
        "type": "string",
        "description": "Internal spacing of the container",
        "required": false,
        "default": "md",
        "options": ["none", "xs", "sm", "md", "lg", "xl"],
        "example": "md"
      },
      "width": {
        "type": "string",
        "description": "Container width - controls responsive behavior",
        "required": false,
        "default": "full",
        "options": ["auto", "full", "fit", "screen"],
        "example": "full"
      }
    },
    "子方塊": [],
    "對外參數": {},
    "程式碼": "",
    "審核狀態": "approved",
    "上架狀態": true,
    "可刪除": false
  },
  {
    "id": "方塊:方塊:網格",
    "名稱": {
      "en": "Grid",
      "zh-tw": "網格",
      "vi": "Grid"
    },
    "描述": {
      "en": "A grid layout container for creating responsive grid layouts. Supports column configuration and responsive breakpoints.",
      "zh-tw": "網格佈局容器，用於創建響應式網格佈局。支援欄位配置和響應式斷點。",
      "vi": "Một container bố cục lưới để tạo bố cục lưới phản ứng. Hỗ trợ cấu hình cột và các điểm ngắt phản ứng."
    },
    "售價": 0,
    "標籤集": ["ui", "grid", "layout", "responsive"],
    "模式": "內建",
    "元件路徑": "ui/Grid",
    "屬性定義": {
      "children": {
        "type": "object",
        "description": "Child elements to arrange in grid layout",
        "required": true,
        "example": "<div>Grid item 1</div><div>Grid item 2</div>"
      },
      "columns": {
        "type": "number",
        "description": "Number of columns in the grid",
        "required": false,
        "default": 2,
        "min": 1,
        "max": 12,
        "example": 3
      },
      "gap": {
        "type": "string",
        "description": "Spacing between grid items",
        "required": false,
        "default": "md",
        "options": ["none", "xs", "sm", "md", "lg", "xl"],
        "example": "md"
      },
      "padding": {
        "type": "string",
        "description": "Internal spacing of the grid container",
        "required": false,
        "default": "md",
        "options": ["none", "xs", "sm", "md", "lg", "xl"],
        "example": "md"
      }
    },
    "子方塊": [],
    "對外參數": {},
