[
  {
    "id": "方塊:方塊:按鈕",
    "名稱": {
      "en": "Button",
      "zh-tw": "按鈕",
      "vi": "Nút bấm"
    },
    "描述": {
      "en": "A clickable button component that triggers actions when clicked. Supports different styles, sizes, and states.",
      "zh-tw": "可點擊的按鈕元件，點擊時觸發動作。支援不同樣式、大小和狀態。",
      "vi": "Một thành phần nút có thể nhấp được kích hoạt hành động khi được nhấp. Hỗ trợ các kiểu, kích thước và trạng thái khác nhau."
    },
    "售價": 0,
    "標籤集": ["ui", "button", "interactive"],
    "模式": "內建",
    "元件路徑": "ui/Button",
    "屬性定義": {
      "children": {
        "type": "object",
        "description": "Content to display inside the button - can be text, icons, or complex JSX",
        "required": true,
        "example": "<span>Click me</span> or <Icon name=\"save\" /><span>Save</span>"
      },
      "variant": {
        "type": "string",
        "description": "Button style variant - controls the visual appearance",
        "required": false,
        "default": "primary",
        "options": ["primary", "secondary", "accent", "outline", "ghost"],
        "example": "primary"
      },
      "size": {
        "type": "string",
        "description": "Button size - controls the padding and font size",
        "required": false,
        "default": "md",
        "options": ["sm", "md", "lg"],
        "example": "md"
      },
      "disabled": {
        "type": "boolean",
        "description": "Whether the button is disabled and cannot be clicked",
        "required": false,
        "default": false,
        "example": false
      },
      "onClick": {
        "type": "function",
        "description": "Function called when button is clicked - for event handling",
        "required": false,
        "example": "() => console.log('Button clicked')"
      },
      "type": {
        "type": "string",
        "description": "Button type for form submission behavior",
        "required": false,
        "default": "button",
        "options": ["button", "submit", "reset"],
        "example": "button"
      }
    },
    "子方塊": [],
    "對外參數": {},
    "程式碼": "",
    "審核狀態": "approved",
    "上架狀態": true,
    "可刪除": false
  },
  {
    "id": "方塊:方塊:輸入框",
    "名稱": {
      "en": "Input Field",
      "zh-tw": "輸入框",
      "vi": "Trường nhập liệu"
    },
    "描述": {
      "en": "A text input field for user input. Supports various input types, validation, and styling options.",
      "zh-tw": "供使用者輸入的文字輸入框。支援各種輸入類型、驗證和樣式選項。",
      "vi": "Một trường nhập văn bản để nhập liệu của người dùng. Hỗ trợ các loại nhập liệu khác nhau, xác thực và tùy chọn kiểu dáng."
    },
    "售價": 0,
    "標籤集": ["ui", "input", "form"],
    "模式": "內建",
    "元件路徑": "ui/Input",
    "屬性定義": {
      "placeholder": {
        "type": "string",
        "description": "Placeholder text displayed when input is empty",
        "required": false,
        "default": "Enter text...",
        "example": "Enter your name"
      },
      "type": {
        "type": "string",
        "description": "Input type - controls browser validation and keyboard type",
        "required": false,
        "default": "text",
        "options": ["text", "email", "password", "number", "tel"],
        "example": "text"
      },
      "value": {
        "type": "string",
        "description": "Current value of the input field",
        "required": false,
        "default": "",
        "example": "John Doe"
      },
      "required": {
        "type": "boolean",
        "description": "Whether the input is required for form validation",
        "required": false,
        "default": false,
        "example": true
      },
      "disabled": {
        "type": "boolean",
        "description": "Whether the input is disabled and cannot be edited",
        "required": false,
        "default": false,
        "example": false
      },
      "onChange": {
        "type": "function",
        "description": "Function called when input value changes - for event handling",
        "required": false,
        "example": "(value) => console.log('Input changed:', value)"
      }
    },
    "子方塊": [],
    "對外參數": {},
    "程式碼": "",
    "審核狀態": "approved",
    "上架狀態": true,
    "可刪除": false
  },
  {
    "id": "方塊:方塊:卡片",
    "名稱": {
      "en": "Card",
      "zh-tw": "卡片",
      "vi": "Thẻ"
    },
    "描述": {
      "en": "A flexible container component for displaying content in a structured layout. Can contain text, images, and other components.",
      "zh-tw": "靈活的容器元件，用於在結構化佈局中顯示內容。可以包含文字、圖片和其他元件。",
      "vi": "Một thành phần container linh hoạt để hiển thị nội dung trong bố cục có cấu trúc. Có thể chứa văn bản, hình ảnh và các thành phần khác."
    },
    "售價": 0,
    "標籤集": ["ui", "card", "container", "layout"],
    "模式": "內建",
    "元件路徑": "ui/Card",
    "屬性定義": {
      "title": {
        "type": "string",
        "description": "Card title displayed at the top",
        "required": false,
        "default": "",
        "example": "Product Card"
      },
      "content": {
        "type": "string",
        "description": "Main content of the card - can be text or HTML",
        "required": false,
        "default": "",
        "example": "This is a beautiful product card with description."
      },
      "image": {
        "type": "string",
        "description": "URL or path to card image - supports web URLs and relative paths",
        "required": false,
        "default": "",
        "example": "/images/product.jpg"
      },
      "variant": {
        "type": "string",
        "description": "Card style variant - controls border and background",
        "required": false,
        "default": "default",
        "options": ["default", "outlined", "elevated"],
        "example": "default"
      },
      "padding": {
        "type": "string",
        "description": "Card padding size - controls internal spacing",
        "required": false,
        "default": "md",
        "options": ["none", "sm", "md", "lg"],
        "example": "md"
      },
      "shadow": {
        "type": "boolean",
        "description": "Whether to show card shadow for depth effect",
        "required": false,
        "default": true,
        "example": true
      }
    },
    "子方塊": [],
    "對外參數": {},
    "程式碼": "",
    "審核狀態": "approved",
    "上架狀態": true,
    "可刪除": false
