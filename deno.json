{
  "nodeModulesDir": "auto",
  "imports": {
    "@dui/smartmultilingual": "jsr:@dui/smartmultilingual@^0.2.2",
    "@emotion/react": "npm:@emotion/react@^11.14.0",
    "@emotion/styled": "npm:@emotion/styled@^11.14.1",
    "@radix-ui/react-avatar": "npm:@radix-ui/react-avatar@^1.1.11",
    "@radix-ui/react-checkbox": "npm:@radix-ui/react-checkbox@^1.3.3",
    "@radix-ui/react-collapsible": "npm:@radix-ui/react-collapsible@^1.1.12",
    "@radix-ui/react-context-menu": "npm:@radix-ui/react-context-menu@^2.2.16",
    "@radix-ui/react-dialog": "npm:@radix-ui/react-dialog@^1.1.15",
    "@radix-ui/react-dropdown-menu": "npm:@radix-ui/react-dropdown-menu@^2.1.16",
    "@radix-ui/react-hover-card": "npm:@radix-ui/react-hover-card@^1.1.15",
    "@radix-ui/react-label": "npm:@radix-ui/react-label@^2.1.8",
    "@radix-ui/react-menubar": "npm:@radix-ui/react-menubar@^1.1.16",
    "@radix-ui/react-navigation-menu": "npm:@radix-ui/react-navigation-menu@^1.2.14",
    "@radix-ui/react-popover": "npm:@radix-ui/react-popover@^1.1.15",
    "@radix-ui/react-progress": "npm:@radix-ui/react-progress@^1.1.8",
    "@radix-ui/react-radio-group": "npm:@radix-ui/react-radio-group@^1.3.8",
    "@radix-ui/react-scroll-area": "npm:@radix-ui/react-scroll-area@^1.2.10",
    "@radix-ui/react-select": "npm:@radix-ui/react-select@^2.2.6",
    "@radix-ui/react-separator": "npm:@radix-ui/react-separator@^1.1.8",
    "@radix-ui/react-slot": "npm:@radix-ui/react-slot@^1.2.4",
    "@radix-ui/react-switch": "npm:@radix-ui/react-switch@^1.2.6",
    "@radix-ui/react-tabs": "npm:@radix-ui/react-tabs@^1.1.13",
    "@radix-ui/react-toast": "npm:@radix-ui/react-toast@^1.2.15",
    "@radix-ui/react-tooltip": "npm:@radix-ui/react-tooltip@^1.2.8",
    "hono": "jsr:@hono/hono@^4.12.7",
    "nanoid": "npm:nanoid@^5.1.6",
    "unocss": "npm:unocss@^66.6.6",
    "@/utils/": "./utils/",
    "@/database/": "./database/",
    "@/src/": "./src/",
    "@/styles/": "./src/styles/"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env --allow-write --unstable-kv main.tsx",
    "serve": "deno task start",
    "uno": "deno run -A npm:@unocss/cli@0.61.9 src/**/*.tsx main.tsx -o public/uno.css",
    "uno:watch": "deno run -A npm:@unocss/cli@0.61.9 src/**/*.tsx main.tsx -o public/uno.css --watch",
    "dev": "deno task uno:watch & deno task start",
    "dev:hot": "deno run --allow-net --allow-read --allow-env --allow-write --unstable-kv --watch main.tsx",
    "dev:full": "deno run --allow-net --allow-read --allow-env --allow-write --unstable-kv dev.tsx",
    "dev:hmr": "deno task uno:watch & deno task dev:full",
    "dev:simple": "deno run --allow-net --allow-read --allow-env --allow-write --unstable-kv dev-simple.tsx",
    "dev:watch": "deno task uno:watch & deno task dev:simple"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  }
}
