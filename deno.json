{
  "nodeModulesDir": "auto",
  "imports": {
    "@dui/smartmultilingual": "jsr:@dui/smartmultilingual@^0.2.2",
    "hono": "jsr:@hono/hono@^4.12.7",
    "nanoid": "npm:nanoid@^5.1.6",
    "unocss": "npm:unocss@^66.6.6",
    "@/utils/": "./utils/",
    "@/database/": "./database/",
    "@/src/": "./src/"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env --allow-write --unstable-kv main.tsx",
    "serve": "deno task start",
    "uno": "deno run -A npm:@unocss/cli@0.61.9 src/**/*.tsx main.tsx -o public/uno.css",
    "uno:watch": "deno run -A npm:@unocss/cli@0.61.9 src/**/*.tsx main.tsx -o public/uno.css --watch",
    "dev": "deno task uno:watch & deno task start"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx"
  }
}
