{
  "version": "1.0.0",
  "tasks": {
    "dev": "deno run -A --unstable-kv main.ts",
    "build": "deno run -A --unstable-kv main.ts --build",
    "start": "deno run -A dist/server.js"
  },
  "imports": {
    "@/": "./",
    "@database": "./database",
    "@dreamer/dweb": "jsr:@dreamer/dweb@^3.0.88",
    "@dreamer/render": "jsr:@dreamer/render@^1.0.38",
    "@dreamer/router": "jsr:@dreamer/router@^1.0.15",
    "@dreamer/plugins": "jsr:@dreamer/plugins@^1.0.6",
    "@dreamer/view": "jsr:@dreamer/view@^1.0.30",
    "@dui/smartmultilingual": "jsr:@dui/smartmultilingual@^0.2.1",
    "std/dotenv": "jsr:@std/dotenv@0.218.2",
    "nanoid": "npm:nanoid@^5.1.6",
    "unocss": "npm:unocss@^66.6.0",
    "@unocss/core": "npm:@unocss/core@^66.6.0",
    "@unocss/preset-attributify": "npm:@unocss/preset-attributify@^66.6.0",
    "@unocss/preset-icons": "npm:@unocss/preset-icons@^66.6.0",
    "@unocss/preset-wind4": "npm:@unocss/preset-wind4@^66.6.0",
    "minio": "npm:minio@^8.0.2",
    "sharp": "npm:sharp@^0.33.0"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@dreamer/view",
    "lib": [
      "deno.ns",
      "deno.unstable",
      "dom"
    ],
    "types": [
      "jsx.d.ts",
      "types.d.ts",
      "deno.ns",
      "deno.unstable"
    ]
  },
  "allowScripts": [
    "npm:better-sqlite3@11.0.0",
    "npm:esbuild@0.27.2"
  ]
}
