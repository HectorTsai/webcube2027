{
  "id": "方塊:方塊:頁尾",
  "名稱": { "en": "Footer", "zh-tw": "頁尾", "vi": "Chân trang" },
  "標籤集": ["方塊:標籤:導覽"],
  "描述": {
    "en": "Page footer section built on Container. Centered column layout with configurable color, padding, and gap. Content is passed as children.",
    "zh-tw": "基於 Container 的頁面頁尾區塊。置中欄佈局，可設定 color、padding 與 gap。內容透過 children 傳入。",
    "vi": "Phần chân trang dựa trên Container. Bố cục cột căn giữa với màu sắc, đệm và khoảng cách có thể cấu hình. Nội dung được truyền qua children."
  },
  "from": "方塊:方塊:容器",
  "declareStores": ["layout"],
  "alpine": {
    "layoutObserver": "footerHeight"
  },
  "defaults": {
    "border": "none",
    "shadow": "none",
    "align": "center",
    "justify": "center",
    "rounded": "none"
  },
  "mergedArgs": {
    "currentYear": "@api/v1/temporal/fullYear",
    "prefix": "@api/v1/translate/copyright",
    "suffix": "@api/v1/translate/all rights reserved"
  },
  "args": {
    "color": {
      "type": "string",
      "description": "色彩主題",
      "default": "base",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"]
    },
    "direction": {
      "type": "string",
      "description": "排列方向",
      "default": "col",
      "options": ["col", "row"]
    },
    "fontSize": {
      "type": "string",
      "description": "字級大小（variants 繼承自容器）",
      "default": "sm",
      "options": ["xs", "sm", "base", "lg", "xl", "2xl", "3xl", "4xl", "5xl"]
    },
    "padding": {
      "type": "string",
      "description": "內距（variants 繼承自容器）",
      "default": "sm",
      "options": ["none", "xs", "sm", "md", "lg", "xl", "2xl"]
    },
    "gap": {
      "type": "string",
      "description": "間距（variants 繼承自容器）",
      "default": "xs",
      "options": ["none", "xs", "sm", "md", "lg", "xl"]
    },
    "className": {
      "type": "string",
      "description": "額外的 CSS 類別，會追加入頂層定義的排版類名後方",
      "default": ""
    },
    "copyright": {
      "type": "object",
      "description": "版權資訊物件，包含 公司、網址、開始年份 等欄位",
      "default": {}
    }
  },
  "children": [
    {
      "from": "方塊:方塊:div",
      "className": "flex items-center justify-center",
      "children": [
        {
          "from": "方塊:方塊:span",
          "text": "{prefix} \u00a9 {copyright.開始年份}-{currentYear}"
        },
        {
          "from": "方塊:方塊:超連結",
          "hover": true,
          "href": "{copyright.網址}",
          "target": "_blank",
          "border": "none",
          "shadow": "none",
          "size": "sm",
          "className": "!py-0",
          "children": [
            {
              "from": "方塊:方塊:span",
              "text": "{copyright.公司}"
            }
          ]
        },
        {
          "from": "方塊:方塊:span",
          "text": "{suffix}."
        }
      ]
    }
  ],
  "可刪除": false
}
