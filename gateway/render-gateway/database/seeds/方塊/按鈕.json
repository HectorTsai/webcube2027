{
  "id": "方塊:方塊:按鈕",
  "名稱": { "en": "Button", "zh-tw": "按鈕", "vi": "Nút" },
  "標籤集": ["方塊:標籤:互動元素"],
  "描述": {
    "en": "Button cube built on Container. Supports color themes, sizes, disabled state, and hover effect.",
    "zh-tw": "按鈕方塊，基於容器建構。支援色彩主題、尺寸、禁用狀態、懸停效果。",
    "vi": "Khối nút, xây dựng trên Container."
  },
  "from": "方塊:方塊:容器",
  "tag": "button",
  "defaults": {
    "type": "button",
    "border": "none",
    "padding": "none",
    "userSelect": "none",
    "cursor": "pointer"
  },
  "className": "inline-flex items-center justify-center",
  "args": {
    "color": {
      "type": "string",
      "description": "色彩主題（current = 繼承父層顏色）",
      "default": "current",
      "options": ["primary", "secondary", "accent", "info", "success", "warning", "error", "base", "neutral"],
      "variants": {
        "current": {},
        "primary": {},
        "secondary": {},
        "accent": {},
        "info": {},
        "success": {},
        "warning": {},
        "error": {},
        "base": {},
        "neutral": {}
      }
    },
    "size": {
      "type": "string",
      "description": "按鈕尺寸（控制內距與字級）",
      "default": "md",
      "options": ["xs", "sm", "md", "lg", "xl"],
      "variants": {
        "xs": { "fontSize": "xs", "rounded": "sm", "padding": "xs" },
        "sm": { "fontSize": "sm", "rounded": "sm", "padding": "sm" },
        "md": { "fontSize": "base", "rounded": "md", "padding": "md" },
        "lg": { "fontSize": "lg", "rounded": "lg", "padding": "lg" },
        "xl": { "fontSize": "xl", "rounded": "lg", "padding": "xl" }
      }
    },
    "disabled": {
      "type": "boolean",
      "description": "是否禁用",
      "default": false
    },
    "active": {
      "type": "boolean",
      "description": "供電狀態（false = neutral 灰階）",
      "default": true
    },
    "hover": {
      "type": "boolean",
      "description": "允許懸停效果",
      "default": true
    }
  },
  "alpine": {
    "五態": true,
    "bind": { "disabled": "{disabled}" }
  },
  "可刪除": false
}
